/* =========================
   GLOBAL
========================= */
@import url("https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap");

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Inter", sans-serif;
  color: #243e63;
}

:root {
  --purple-main: #654dfc;
  --purple-dark: #3716ca;
  --purple-light: #eceaf2;
  --text-dark: #1f2937;
}

html {
  scroll-behavior: smooth;
}

body {
  max-width: 100vw;
  overflow-x: hidden;
  background-color: var(--purple-light);
}

a {
  text-decoration: none;
  color: inherit;
}

button {
  cursor: pointer;
  border: none;
}

/* =========================
   LAYOUT HELPERS
========================= */
.row {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}

/* =========================
   NAVIGATION
========================= */
nav {
  padding: 12px 24px;
  background-color: var(--purple-light);
}

.nav__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Logo */
.nav__logo {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-right: auto;
}

.nav__logo--img {
  height: 32px;
}

.nav__logo--title {
  font-size: 20px;
  font-weight: bold;
}

/* Desktop Links */
.nav__links {
  display: flex;
  gap: 24px;
  align-items: center;
  position: relative;
}

.nav__links-wrapper {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 16px;
}

.nav__link:hover {
  color: var(--purple-main);
}

/* CTA button */
.nav__link:last-child {
  background-color: var(--purple-main);
  color: #fff;
  padding: 8px 16px;
  border-radius: 999px;
}

.nav__link:last-child:hover {
  background-color: var(--purple-dark);
}

/* =========================
   HAMBURGER BUTTON
========================= */
.btn__menu {
  display: none;
  position: relative;
  top: -4px;
  background: transparent;
 
}

.btn__menu svg {
  width: 32px;
  height: 32px;
}

/* =========================
   MOBILE MENU (BLUR OVERLAY)
========================= */
.menu__backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;

  display: flex;
  justify-content: center;
  align-items: center;

  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);

  transform: translateX(100%);
  transition: transform 0.4s ease;

  z-index: 1000;
}

.menu--open .menu__backdrop {
  transform: translateX(0);
}

/* Mobile Links */
.menu__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.menu__link {
  color: white;
  font-size: 28px;
  font-weight: 600;
  position: relative;
  transition: all 0.3s ease;
}

.menu__link:hover {
  transform: scale(1.1);
  color: #a78bfa;
}

/* underline animation */
.menu__link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -6px;
  width: 0%;
  height: 2px;
  background: #a78bfa;
  transition: width 0.3s ease;
}

.menu__link:hover::after {
  width: 100%;
}

/* hide hamburger when open */
.menu--open .btn__menu {
  opacity: 0;
  pointer-events: none;
}

/* =========================
   HEADER
========================= */
header {
  padding: 80px 0;
}

header .row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}

.header__description {
  width: 50%;
}

.header__img--wrapper {
  width: 50%;
  display: flex;
  justify-content: center;
}

.header__img {
  width: 100%;
  max-width: 600px;
}

.header__customer--title {
  font-size: 12px;
  letter-spacing: 1px;
  color: #999;
  margin-bottom: 12px;
}

.header__description img {
  width: 100%;
  max-width: 400px;
  opacity: 0.7;
}

h1 {
  font-size: 48px;
  line-height: 1.2;
  margin-bottom: 24px;
}

.purple {
  color: var(--purple-main);
}

.header__description--para {
  font-size: 18px;
  line-height: 1.6;
  margin-bottom: 32px;
  color: #1f2937;
}

.header__email {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 999px;
  padding: 6px;
  max-width: 999px;
  margin-bottom: 32px;
}

.header__email--input {
  border: none;
  outline: none;
  background: transparent;
  flex: 1;
  padding: 12px 16px;
  font-size: 16px;
}

.header__email--btn {
  background-color: var(--purple-main);
  width: 100%;
  max-width: 160px;
  color: white;
  border: none;
  padding: 14px 0px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.header__email--btn:hover {
  background-color: rgba(60, 13, 153);
}


.header__email--input::placeholder {
  font-weight: 500;
  color: rgb(158, 170, 189);
}

.header__email--input:hover {
  border-color: rgb(167, 175, 192);
}

.header__email--input:focus,
.header__email--input:active {
  outline: none;
  border-color: rgba(100, 21, 255);
}

/* =========================
        FEATURES
========================= */

#features {
  padding: 100px 0;
  text-align: center;
}

.feature__row {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.section__tag {
  color: var(--purple-main);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 2px;
  margin-bottom: 16px;
}

.section__title {
  font-size: 40px;
  margin-bottom: 16px;
}

.section__para {
  max-width: 600px;
  margin: 0 auto 60px auto;
  color: #1f2937;
  line-height: 1.6;
}

.features {
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  justify-content: space-between;
}

.feature {
  width: calc(33.333% - 27px);
}

.feature__img--wrapper {
  background-color: #f5f5f5;
  border-radius: 999px;
  padding: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature__img {
  width: 24px;
  height: 24px;
}

.feature__title {
  font-size: 18px;
  margin-bottom: 8px;
}

.feature__para {
  font-size: 14px;
  color: var(--text-dark);
  line-height: 1.6;
}

.feature {
  transition: transform 0.3s ease;
}

.feature:hover {
  transform: translateY(-6px);
}

/* =========================
        QUALITY
========================= */
#quality {
  padding: 100px 0;
}

.quality__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 64px;
}

.quality__description {
  width: 50%;
  max-width: 520px;
}

.quality__img--wrapper {
  width: 50%;
  position: relative; /* needed for the grid */
}

.section__tag {
  color: var(--purple-main);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 1.5px;
  margin-bottom: 16px;
}

.section__title {
  font-size: 40px;
  line-height: 1.3;
  margin-bottom: 24px;
}

.section__para {
  font-size: 16px;
  color: #1f2937;
  line-height: 1.7;
  margin-bottom: 32px;
}

.btn {
  background-color: var(--purple-main);
  width: 100%;
  max-width: 160px;
  color: white;
  border: none;
  padding: 14px 0px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn:hover {
  background-color: var(--purple-dark);
}

.quality__img {
  width: 100%;
  border-radius: 8px;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.quality__grid {
  position: absolute;
  bottom: -40px;
  right: -40px;
  width: 120px;
  opacity: 0.2;
  z-index: -1;
  color: var(--purple-main);
}

.quality__img {
  transition: transform 0.4s ease;
}

.quality__img:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 40px rgba(100, 21, 255, 0.25);
}

/* =========================
          STEPS
========================= */
.steps__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 48px;
}

.steps__img--wrapper {
  width: 50%;
  position: relative; /* needed for SVG positioning */
}

.steps__img {
  width: 100%;
  display: block;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.steps__grid {
  position: absolute;
  top: -40px;
  left: -40px;
  z-index: 0;
  width: 100%;
  max-width: 500px;
  pointer-events: none;
}

.steps__img {
  position: relative;
  z-index: 1;
  border-radius: 12px; /* optional but looks clean */
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}

.steps__img--wrapper {
  transform: translateX(-20px);
}

.steps__img {
  width: 100%;
  max-width: 600px;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}

.steps__img:hover {
  transform: scale(1.05) translateY(-8px);
  box-shadow: 0 25px 50px rgba(0,0,0,0.15);
}

.steps__img:hover {
  box-shadow: 0 20px 40px rgba(100, 21, 255, 0.25);
}


/* =========================
          VALUES
========================= */
#values .row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 64px;
}

.values__description {
  width: 50%;
  max-width: 520px;
}

.values__img {
  width: 50%;
  max-width: 500px;
}

.values__list {
  display: flex;
  gap: 32px;
  margin: 32px 0;
}

.value {
  flex: 1;
}

.value__title {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.value__img {
  width: 20px;
  height: 20px;
}
.value:nth-child(1) .value__img--wrapper {
  background-color: #9ae6b4;
}
.value:nth-child(2) .value__img--wrapper {
  background-color: #feb2b2;
}
.value__img--wrapper {
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 32px;
  height: 32px;
}

.value__name {
  font-weight: 700;
  font-size: 18px;
}

.value__para {
  font-size: 14px;
  line-height: 1.6;
  color: var(--text-dark);
}

.btn {
  background: var(--purple-main);
  color: #fff;
  border: none;
  padding: 12px 24px;
  border-radius: 999px;
  cursor: pointer;
  transition: 0.3s;
}

.btn:hover {
  background: var(--purple-dark);
  transform: translateY(-2px);
}

.values__img {
  border-radius: 12px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}

/* =========================
          PRICING
========================= */
#pricing {
  padding: 100px 0;
  text-align: center;
}

.pricing__row {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;   /* THIS centers everything */
  padding: 0 20px;
}

.section__tag {
  color: var(--purple-main);
  font-weight: 700;
  letter-spacing: 2px;
  font-size: 14px;
  margin-bottom: 16px;
  text-transform: uppercase;
}

.section__title {
  font-size: 40px;
  margin-bottom: 16px;
}

.section__para {
  max-width: 500px;
  color: #666;
  line-height: 1.6;
}

.plans {
  display: flex;
  gap: 32px;
  width: 100%;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.plan {
  background: #fff;
  border-radius: 16px;
  width: 100%;
  max-width: 320px;
  overflow: hidden;
  box-shadow: 0 15px 35px rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  position: relative;
}

.plan:hover {
  transform: translateY(-12px);
  box-shadow: 0 25px 60px var(--purple-dark)
}

.plan__stripe {
  height: 5px;
  background: var(--purple-main);
}

.plan__top {
  padding: 32px 24px;
}

.plan__name {
  font-size: 13px;
  font-weight: 700;
  color: #888;
  letter-spacing: 1px;
}

.plan__price {
  font-size: 42px;
  font-weight: 800;
  margin: 12px 0;
}

.plan__duration {
  font-size: 13px;
  color: #aaa;
}

.plan__middle {
  padding: 24px;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}

.plan__target {
  font-weight: 700;
  margin-bottom: 16px;
}

.plan__feature {
  margin: 10px 0;
  color: var(--text-dark);
}

.plan__button {
  background: var(--purple-main);
  color: white;
  border: none;
  padding-top: 1rem;
  padding-bottom: 1rem;
  padding: 0.75rem 2rem;
  border-radius: 999px;
  font-size: 0.875rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
}

.plan__button:hover {
  background: rgb(66, 38, 66);
  transform: scale(1.05);
}

.plan:nth-child(2) {
  transform: scale(1.06);
  box-shadow: 0 25px 70px rgba(0,0,0,0.2);
  z-index: 2;
}

.plan {
  position: relative;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  z-index: 1;
}

/* gradient layer */
.plan::before {
  content: "";
  position: absolute;
  inset: -2px;
  background: linear-gradient(120deg, #7c3aed, #06b6d4, #7c3aed);
  background-size: 200% 200%;
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 18px;
}

/* animate on hover */
.plan:hover::before {
  opacity: 1;
  animation: gradientMove 3s ease infinite;
}

@keyframes gradientMove {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.plan__button {
  width: 100%;
  max-width: 160px;
  background-size: 200% 200%;
  color: white;
  border: none;
  padding: 14px 0px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.3s ease;
}

/* animate on hover */
.plan__button:hover {
  animation: gradientMove 2s ease infinite;
  transform: scale(1.05);
}

.plan:nth-child(2)::before {
  opacity: 1;
  animation: gradientMove 4s ease infinite;
}

.plan__bottom {
  display: flex;
  justify-content: center;
  padding: 24px;
}

/* =========================
        TESTIMONIALS
========================= */
#testimonials {
  padding: 120px 0;
  background: var(--purple-light);
}

.row {
  max-width: 1100px;
  margin: 0 auto;
}

.testimonials__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 64px;
}

/* LEFT SIDE */
.testimonials__description {
  flex: 1;
  max-width: 520px;
}

/* RIGHT SIDE IMAGE */
.testimonials__img--wrapper {
  flex: 1;
  display: flex;
  justify-content: center;
}

.testimonials__img--wrapper img {
  width: 100%;
  max-width: 500px;
}

/* TEXT */
.section__tag {
  color: var(--purple-main);
  font-weight: 700;
  letter-spacing: 2px;
  font-size: 14px;
  margin-bottom: 16px;
}

.section__title {
  font-size: 48px;
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 16px;
}

.purple {
  color: var(--purple-main);
}

.section__para {
  color: var(--text-dark);
  line-height: 1.6;
  margin-bottom: 32px;
}

/* TESTIMONIAL */
.testimonial__rating {
  color: #fbbf24;
  font-size: 20px;
  margin-bottom: 12px;
}

.testimonial__title {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 12px;
}

.testimonial__para {
  color: var(--text-dark);
  line-height: 1.7;
  margin-bottom: 24px;
}

/* PROFILE */
.testimonial__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.testimonial__profile {
  display: flex;
  align-items: center;
  gap: 12px;
}

.testimonial__profile img {
  width: 48px;
  height: 48px;
  border-radius: 50%;
}

.testimonial__name {
  font-weight: 700;
}

.testimonial__role {
  font-size: 14px;
  color: #7c8ba1;
}

/* BUTTONS */
.testimonial__buttons {
  display: flex;
  gap: 12px;
}

.testimonial__buttons button {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: #d6d7da;
  cursor: pointer;
  font-size: 16px;
  transition: 0.3s;
}

.testimonial__buttons button:hover {
  background: #6415ff;
  color: white;
}

/* =========================
          START
========================= */

/* =========================
          FOOTER
========================= */

/* ======================
   MOBILE RESPONSIVE
========================= */
@media (max-width: 768px) {

  /* hide desktop nav */
  .nav__links {
    display: none;
  }

  /* show hamburger */
  .btn__menu {
    display: flex;
  }

  /* stack layout */
  .row {
    flex-direction: column;
    text-align: center;
  }

  h1 {
    font-size: 28px;
  }

  p {
    font-size: 16px;
  }

  section {
    padding: 60px 20px;
  }
}

@media (max-width: 768px) {
  header .row {
    flex-direction: column;
    text-align: center;
  }

  .header__description,
  .header__img--wrapper {
    width: 100%;
  }

  .header__email {
    margin: 0 auto 32px auto;
  }
}

@media (max-width: 1024px) {
  .feature {
    width: calc(50% - 20px);
  }
}

@media (max-width: 640px) {
  .feature {
    width: 100%;
  }

  .feature__row {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .feature {
  transition: transform 0.3s ease;
}

.feature:hover {
  transform: translateY(-6px);
}
}

@media (max-width: 768px) {
  .quality__row {
    flex-direction: column;
    text-align: center;
  }

  .quality__description,
  .quality__img--wrapper {
    width: 100%;
  }

  .quality__grid {
    display: none;
  }
}

@media (max-width: 768px) {
  .steps__row {
    flex-direction: column;
    text-align: center;
  }

  .steps__img--wrapper,
  .steps__content {
    width: 100%;
  }

  .steps__grid {
    display: none; /* cleaner on mobile */
  }
}

@media (max-width: 768px) {
  #values .row {
    flex-direction: column;
    text-align: center;
  }

  .values__description,
  .values__img {
    width: 100%;
  }

  .values__list {
    flex-direction: column;
  }

  .value__title {
    justify-content: center;
  }
}

@media (max-width: 768px) {
  .plans {
    flex-direction: column;
    align-items: center;
  }

  .plan:nth-child(2) {
    transform: none;
  }

  .plan:hover{
    transform: translateY(-12px);
    box-shadow: 0 25px 60px var(--purple-dark);
  }

  @media (max-width: 768px) {
  .testimonials__row {
    flex-direction: column;
    text-align: center;
  }

  .testimonial__bottom {
    flex-direction: column;
    gap: 16px;
  }

  .testimonials__description {
    max-width: 100%;
  }
}
}

@media (max-width: 768px) {
  .testimonials__row {
    flex-direction: column;
    text-align: center;
  }

  .testimonial__bottom {
    flex-direction: column;
    gap: 16px;
  }
}
